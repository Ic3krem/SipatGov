# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/sipatgov_db
DB_TYPE=postgresql

# Alternative: MongoDB
# MONGO_URL=mongodb://localhost:27017/sipatgov_db
# DB_TYPE=mongodb

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False
RELOAD=False

# GPU Configuration (for RTX 5060 Ti: CUDA 12.1)
USE_GPU=True
GPU_ID=0

# OCR Configuration
OCR_BATCH_SIZE=4
OCR_MODEL=paddleocr

# NLP Configuration
NLP_MODEL=facebook/bart-large-mnli
ENTITY_MODEL=dbmdz/bert-base-multilingual-cased-ner-wnut17

# Crawling Configuration
CRAWL_TIMEOUT=30
CRAWL_RETRY_ATTEMPTS=3
MAX_URLS_PER_LGU=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/server.log

# Data Directories
DOWNLOAD_DIR=downloads/
PROCESSED_DIR=processed_data/
